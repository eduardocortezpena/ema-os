DATABASE_URL="file:./emaos.db"

# Google Cloud Console → APIs & Services → Credentials → tu OAuth client "Desktop app"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Clave de 32 bytes en hexadecimal (64 caracteres) para cifrar el refresh token en SQLite.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
