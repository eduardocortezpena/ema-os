generator client {
  provider = "prisma-client"
  output   = "../app/lib/prisma"
}

datasource db {
  provider = "sqlite"
}

model Proyecto {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    Priority @default(LOW)
  status      Status   @default(PLANNING)
  progress    Int      @default(0)
  nextAction  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Tarea[]  @relation("ProjectTasks")
  notes       Nota[]
  nextActionTaskId String? @unique
  nextActionTask   Tarea?  @relation("ProjectNextAction", fields: [nextActionTaskId], references: [id])
  archivos         Archivo[]
  // Plantillas de documentos para este proyecto (Sprint 6.1)
  templates        DocumentTemplate[]
  // Carpeta del proyecto en Drive (Sprint 3.4). Nullable: se crea de forma
  // perezosa en el primer upload, no al crear el proyecto (createProject no
  // depende de red/Drive).
  driveFolderId    String?
}

model Tarea {
  id          String   @id @default(cuid())
  // Nullable (Sprint 7.4, Quick Capture): una tarea sin projectId es un
  // ítem del inbox — capturado sin clasificar todavía. "Clasificar" es un
  // update de este campo, nada más. Invariante: una tarea de inbox NUNCA
  // puede ser nextActionTask de un proyecto (Proyecto.tasks es la relación
  // inversa por FK, así que projectId=null la excluye automáticamente del
  // <select> de Next Action sin guard adicional).
  projectId   String?
  title       String
  description String?
  priority    Priority @default(LOW)
  status      TareaStatus @default(TODO)
  dueDate     DateTime?
  // Preset de recordatorios del evento de Calendar (Sprint 4.3). DEFAULT =
  // 3 y 5 días antes (sin que el usuario tenga que elegir nada). Solo tiene
  // efecto si la tarea llega a tener un evento (proyecto + dueDate).
  reminderPreset ReminderPreset @default(DEFAULT)
  plannedFor  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Sello de finalización (UX tareas v2): se setea al pasar a DONE y se
  // limpia al volver a un estado no-DONE (ver updateTaskStatus). Aditivo,
  // nullable, sin backfill — las tareas DONE pre-existentes quedan null y
  // simplemente no aparecen en "Completadas recientes" ni entran en la purga
  // de >30 días (que filtra por completedAt).
  completedAt DateTime?
  project     Proyecto? @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: SetNull)
  notes       Nota[]
  isNextActionFor Proyecto? @relation("ProjectNextAction")
  // Evento espejo en Google Calendar (Sprint 4.2). Mismo patrón que
  // Archivo.driveFileId: nullable, solo tareas CON proyecto y dueDate lo
  // tienen. Migración aditiva, sin backfill (tareas existentes quedan null).
  eventId     String?
}

model Nota {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  project   Proyecto @relation(fields: [projectId], references: [id])
  taskId    String?
  task      Tarea?   @relation(fields: [taskId], references: [id])
}

model Archivo {
  id           String      @id @default(cuid())
  projectId    String
  project      Proyecto    @relation(fields: [projectId], references: [id])
  kind         ArchivoKind
  title        String
  path         String
  mimeType     String?
  driveFileId  String?
  // Trazabilidad de la migración Nota->Archivo (Sprint 3.3). Nullable:
  // solo las notas migradas lo tienen. @unique para que el backfill sea
  // idempotente (no duplica). Se retira cuando se dropee el modelo Nota.
  sourceNotaId String?     @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum ArchivoKind {
  NOTE
  FILE
}

model GoogleDriveToken {
  id                   String    @id @default("default")
  refreshTokenCipher   String
  refreshTokenIv       String
  refreshTokenAuthTag  String
  accessToken          String?
  accessTokenExpiresAt DateTime?
  updatedAt            DateTime  @updatedAt
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
}

enum TareaStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
}

enum ReminderPreset {
  DEFAULT
  THREE_DAYS
  FIVE_DAYS
  ONE_DAY
  NONE
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  name        String
  // "docx" o "md" según el tipo de plantilla
  docType     String
  // Ruta relativa a ./templates/ donde se guarda el archivo .docx o .md
  path        String
  // Variables JSON esperadas por la plantilla (ej: {"fields": ["nombre", "fecha", "monto"]})
  variables   String?  @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Relación opcional a proyecto para plantillas específicas
  projectId   String?
  project     Proyecto? @relation(fields: [projectId], references: [id])
}