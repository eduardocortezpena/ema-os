generator client {
  provider = "prisma-client"
  output   = "../app/lib/prisma"
}

datasource db {
  provider = "sqlite"
}

model Proyecto {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    Priority @default(LOW)
  status      Status   @default(PLANNING)
  progress    Int      @default(0)
  nextAction  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Tarea[]  @relation("ProjectTasks")
  notes       Nota[]
  nextActionTaskId String? @unique
  nextActionTask   Tarea?  @relation("ProjectNextAction", fields: [nextActionTaskId], references: [id])
  archivos         Archivo[]
  // Carpeta del proyecto en Drive (Sprint 3.4). Nullable: se crea de forma
  // perezosa en el primer upload, no al crear el proyecto (createProject no
  // depende de red/Drive).
  driveFolderId    String?
}

model Tarea {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  priority    Priority @default(LOW)
  status      TareaStatus @default(TODO)
  dueDate     DateTime?
  plannedFor  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Proyecto @relation("ProjectTasks", fields: [projectId], references: [id])
  notes       Nota[]
  isNextActionFor Proyecto? @relation("ProjectNextAction")
}

model Nota {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  project   Proyecto @relation(fields: [projectId], references: [id])
  taskId    String?
  task      Tarea?   @relation(fields: [taskId], references: [id])
}

model Archivo {
  id           String      @id @default(cuid())
  projectId    String
  project      Proyecto    @relation(fields: [projectId], references: [id])
  kind         ArchivoKind
  title        String
  path         String
  mimeType     String?
  driveFileId  String?
  // Trazabilidad de la migración Nota->Archivo (Sprint 3.3). Nullable:
  // solo las notas migradas lo tienen. @unique para que el backfill sea
  // idempotente (no duplica). Se retira cuando se dropee el modelo Nota.
  sourceNotaId String?     @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum ArchivoKind {
  NOTE
  FILE
}

model GoogleDriveToken {
  id                   String    @id @default("default")
  refreshTokenCipher   String
  refreshTokenIv       String
  refreshTokenAuthTag  String
  accessToken          String?
  accessTokenExpiresAt DateTime?
  updatedAt            DateTime  @updatedAt
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Status {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
}

enum TareaStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
}